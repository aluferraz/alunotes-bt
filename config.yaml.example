bluetooth:
  # HCI adapter for A2DP sink role (receives audio from phones).
  # Usually the onboard Raspberry Pi adapter.
  sink_adapter: hci0
  # HCI adapter for A2DP source role (sends audio to headphones).
  # Use a USB Bluetooth dongle (e.g. ASUS USB-BT500).
  # Leave empty to use sink_adapter for both (single-adapter mode).
  source_adapter: hci1
  # Name advertised to Bluetooth source devices (phones, laptops).
  # Leave empty to auto-generate a unique name: "Alunotes-{id}".
  sink_name: ""
  # Path to persist the auto-generated device ID. Default: /var/lib/alunotes-bridge/device_id
  # device_id_file: /var/lib/alunotes-bridge/device_id
  # MAC address of the real headphone to forward audio to.
  # Leave empty to run in record-only mode (no forwarding).
  target_headphone: ""
  # Automatically connect to the target headphone on startup.
  auto_connect: true

audio:
  sample_rate: 44100
  channels: 2
  bit_depth: 16
  # PCM frames per pipeline buffer.
  buffer_size: 1024
  # Go channel buffer capacity between pipeline stages.
  channel_buffer: 64

session:
  # End a session after this duration of silence.
  idle_timeout: 30s
  # PCM amplitude below this is considered silence (0-32768).
  silence_threshold: 100

storage:
  # Root directory for recordings.
  # Structure: base_dir/YYYY-MM-DD/HH-MM-SS/recording.wav
  # Default stores inside the web app's public dir so Next.js can serve them.
  base_dir: ./alunotes-bt-web/public/recordings
  format: wav

# HTTP API server address for the web control plane.
api_addr: ":8090"
