[Unit]
Description=AluNotes Bluetooth A2DP Audio Bridge
After=bluetooth.service alunotes-bt-rfkill.service
Requires=bluetooth.service
Wants=alunotes-bt-rfkill.service

[Service]
Type=simple
User=root
WorkingDirectory=@PROJECT_DIR@
ExecStart=@PROJECT_DIR@/bin/alunotes-bridge -config config.yaml -api-addr :8090
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

# Give BlueZ time to initialize adapters.
ExecStartPre=/bin/sleep 2

# Safety net: power off all BT adapters even after SIGKILL/crash.
# The Go binary handles this on graceful shutdown; this covers ungraceful exits.
ExecStopPost=-@PROJECT_DIR@/deploy/bt-poweroff.sh

[Install]
WantedBy=multi-user.target
