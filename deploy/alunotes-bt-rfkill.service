[Unit]
Description=Unblock Bluetooth USB adapter (hci0) on boot
DefaultDependencies=no
Before=bluetooth.service alunotes-bridge.service
After=sys-subsystem-bluetooth-devices-hci0.device

[Service]
Type=oneshot
ExecStart=/usr/sbin/rfkill unblock 0
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
